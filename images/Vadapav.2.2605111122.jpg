ipe-Step-By-Step-Instructions-3.jpg","datePublished":"2017-02-21T02:48:10+00:00","dateModified":"2024-08-04T02:54:22+00:00","description":"Vada Pav is an Indian Street food made by stuffing deep fried potato fritters in lightly toasted buns and served with spicy chutneys.","breadcrumb":{"@id":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#breadcrumb"},"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#primaryimage","url":"https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3.jpg","contentUrl":"https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3.jpg","width":2400,"height":2000,"caption":"Vada Pav Recipe Step By Step Instructions"},{"@type":"BreadcrumbList","@id":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://vegecravings.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://vegecravings.com/category/recipes/"},{"@type":"ListItem","position":3,"name":"Snacks","item":"https://vegecravings.com/category/recipes/snacks/"},{"@type":"ListItem","position":4,"name":"Vada Pav Recipe | Mumbai Style Pav &#038; Batata Vada"}]},{"@type":"WebSite","@id":"https://vegecravings.com/#website","url":"https://vegecravings.com/","name":"VegeCravings","description":"Authentic Indian Vegetarian Recipes","publisher":{"@id":"https://vegecravings.com/#/schema/person/5e42b8410db5f45b4ec64445cbdc0278"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://vegecravings.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":["Person","Organization"],"@id":"https://vegecravings.com/#/schema/person/5e42b8410db5f45b4ec64445cbdc0278","name":"VegeCravings","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://vegecravings.com/#/schema/person/image/","url":"https://vegecravings.com/wp-content/uploads/2016/02/vegecravings-logo.png","contentUrl":"https://vegecravings.com/wp-content/uploads/2016/02/vegecravings-logo.png","width":756,"height":708,"caption":"VegeCravings"},"logo":{"@id":"https://vegecravings.com/#/schema/person/image/"},"description":"This website began with my desire to recreate &amp; document cherished home-cooked recipes, evolving into a collection of delicious vegetarian dishes from India &amp; around the globe. Each recipe on VegeCravings is either a treasured family recipe or meticulously tested by me. These are the recipes I turn to when cooking for myself, and I hope they become your go-to favorites as well.","sameAs":["http://vegecravings.com","https://www.facebook.com/vegecravings/","https://www.instagram.com/vegecravings/","https://in.pinterest.com/vegecravings/","https://x.com/vegecravings","https://www.youtube.com/channel/UCzCQWICGYp7WUvVHTYHGTOA"],"publishingPrinciples":"https://vegecravings.com/about/","actionableFeedbackPolicy":"https://vegecravings.com/contact-us/"},{"@type":"Recipe","name":"Vada Pav Recipe | Mumbai Style Pav &amp; Batata Vada","author":{"@type":"Person","name":"VegeCravings"},"description":"Vada Pav is an Indian Street food made by stuffing deep fried potato fritters in lightly toasted buns and served with spicy chutneys.","datePublished":"2017-02-21T02:48:10+00:00","image":["https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3.jpg","https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3-500x500.jpg","https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3-500x375.jpg","https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3-480x270.jpg"],"recipeYield":["4"],"prepTime":"PT20M","cookTime":"PT25M","totalTime":"PT45M","recipeIngredient":["3 Medium Sized Potato","7-8  Curry Leaves","2  Green Chillies","3  Garlic Cloves","1/2 Inch Ginger","1/2 Teaspoon Rai (Black Mustard Seeds)","1/2 Teaspoon Red Chilli Powder","1/2 Teaspoon Turmeric Powder (Haldi)","1/4 Teaspoon Heeng (Asafoetida)","1 Teaspoon Salt","1 Tablespoon Cooking Oil","1 Cup Besan (Gram Flour)","1 Teaspoon Salt","1/2 Teaspoon Red Chilli Powder","1/2 Teaspoon Turmeric Powder (Haldi)","1 Cup Cooking Oil","4  Pav (Whole wheat burger buns)","2 Tablespoons Green Chutney (Coriander Chuntney)","2 Tablespoons Tamarind Chutney (Imli Ki Chutney)","2 Tablespoons Dry Garlic Chutney","2 Tablespoons Butter"],"recipeInstructions":[{"@type":"HowToStep","text":"Prepare green chutney. You can store this in the refrigerator for upto a week, or in the freezer for 2-3 weeks.","name":"Prepare green chutney. You can store this in the refrigerator for upto a week, or in the freezer for 2-3 weeks.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-0","image":"https://vegecravings.com/wp-content/uploads/2016/12/coriander-tomato-chutney-recipe-step-by-step-instructions.jpg"},{"@type":"HowToStep","text":"Prepare tamarind chutney (imli ki chutney). This chutney can be refrigerated for upto a month.","name":"Prepare tamarind chutney (imli ki chutney). This chutney can be refrigerated for upto a month.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-1","image":"https://vegecravings.com/wp-content/uploads/2016/04/tamarind-chutney-recipe-step-by-step-instructions.jpg"},{"@type":"HowToStep","text":"Prepare dry garlic chutney. You can store this chutney also for 4-5 days.","name":"Prepare dry garlic chutney. You can store this chutney also for 4-5 days.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-2","image":"https://vegecravings.com/wp-content/uploads/2016/03/dry-garlic-chutney-step-by-step-recipe.jpg"},{"@type":"HowToStep","text":"Heat oil in a pan and add rai (mustard seeds). When the seeds start to crackle, add curry leaves along with paste of ginger, garlic and green chillies.","name":"Heat oil in a pan and add rai (mustard seeds). When the seeds start to crackle, add curry leaves along with paste of ginger, garlic and green chillies.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-3","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-1.jpg"},{"@type":"HowToStep","text":"Add turmeric powder, red chilli powder, heeng (asafoetida) and salt to the pan.","name":"Add turmeric powder, red chilli powder, heeng (asafoetida) and salt to the pan.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-4","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-2.jpg"},{"@type":"HowToStep","text":"Mash the boiled potatoes and add this mixture to them.","name":"Mash the boiled potatoes and add this mixture to them.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-5","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-3.jpg"},{"@type":"HowToStep","text":"Mix everything well to coat the potatoes with the spices.","name":"Mix everything well to coat the potatoes with the spices.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-6","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-4.jpg"},{"@type":"HowToStep","text":"Take gram flour in a mixing bowl and add salt, red chilli powder &amp; turmeric powder to the mixture.","name":"Take gram flour in a mixing bowl and add salt, red chilli powder &amp; turmeric powder to the mixture.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-7","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-5.jpg"},{"@type":"HowToStep","text":"Add roughly 1/2 cup water slowly to get a batter of coating consistency.","name":"Add roughly 1/2 cup water slowly to get a batter of coating consistency.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-8","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-6.jpg"},{"@type":"HowToStep","text":"Heat oil in a pan for frying. Make small balls of the potato filling and dip them in the batter.","name":"Heat oil in a pan for frying. Make small balls of the potato filling and dip them in the batter.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-9","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-7.jpg"},{"@type":"HowToStep","text":"Then fry the balls on medium-high flame till they turn golden brown.","name":"Then fry the balls on medium-high flame till they turn golden brown.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-10","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions-8.jpg"},{"@type":"HowToStep","text":"After frying, drain the vadas on an absorbent paper to drain the excess oil.","name":"After frying, drain the vadas on an absorbent paper to drain the excess oil.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-11","image":"https://vegecravings.com/wp-content/uploads/2016/12/batata-vada-recipe-step-by-step-instructions.jpg"},{"@type":"HowToStep","text":"To assemble, slice the pav buns in half and lightly toast them in butter. Spread the green chutney, tamarind chutney and dry garlic chutney on the pav and place the prepared batata vada in between. Vada Pav is ready. Serve it hot.","name":"To assemble, slice the pav buns in half and lightly toast them in butter. Spread the green chutney, tamarind chutney and dry garlic chutney on the pav and place the prepared batata vada in between. Vada Pav is ready. Serve it hot.","url":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#wprm-recipe-22558-step-0-12","image":"https://vegecravings.com/wp-content/uploads/2017/02/Vada-Pav-Recipe-Step-By-Step-Instructions-3.jpg"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.84","ratingCount":"61"},"recipeCategory":["Snacks"],"recipeCuisine":["Indian"],"suitableForDiet":["https://schema.org/VeganDiet","https://schema.org/VegetarianDiet"],"keywords":"Bread, indian street food, Maharashtrian Recipes, Potatoes, Tea Time Snacks, Tiffin Recipes, Vegan","nutrition":{"@type":"NutritionInformation","calories":"295 kcal","carbohydrateContent":"40 g","proteinContent":"7 g","fatContent":"15 g","servingSize":"1 serving"},"@id":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#recipe","isPartOf":{"@id":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/#article"},"mainEntityOfPage":"https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/"}]}</script> <link rel='dns-prefetch' href='//www.googletagmanager.com' /><link rel='dns-prefetch' href='//pagead2.googlesyndication.com' /><link href='https://fonts.gstatic.com' crossorigin rel='preconnect' /><link href='https://fonts.googleapis.com' crossorigin rel='preconnect' /><link rel="alternate" type="application/rss+xml" title="VegeCravings &raquo; Feed" href="https://vegecravings.com/feed/" /><link rel="alternate" type="application/rss+xml" title="VegeCravings &raquo; Comments Feed" href="https://vegecravings.com/comments/feed/" /><link rel="alternate" type="application/rss+xml" title="VegeCravings &raquo; Vada Pav Recipe | Mumbai Style Pav &#038; Batata Vada Comments Feed" href="https://vegecravings.com/vada-pav-recipe-mumbai-style-batata-vada/feed/" /><link rel="alternate" type="application/rss+xml" title="VegeCravings &raquo; Stories Feed" href="https://vegecravings.com/web-stories/feed/"><script type="litespeed/javascript">(()=>{"use strict";const e=[400,500,600,700,800,900],t=e=>`wprm-min-${e}`,n=e=>`wprm-max-${e}`,s=new Set,o="ResizeObserver"in window,r=o?new ResizeObserver((e=>{for(const t of e)c(t.target)})):null,i=.5/(window.devicePixelRatio||1);function c(s){const o=s.getBoundingClientRect().width||0;for(let r=0;r<e.length;r++){const c=e[r],a=o<=c+i;o>c+i?s.classList.add(t(c)):s.classList.remove(t(c)),a?s.classList.add(n(c)):s.classList.remove(n(c))}}function a(e){s.has(e)||(s.add(e),r&&r.observe(e),c(e))}!function(e=document){e.querySelectorAll(".wprm-recipe").forEach(a)}();if(new MutationObserver((e=>{for(const t of e)for(const e of t.addedNodes)e instanceof Element&&(e.matches?.(".wprm-recipe")&&a(e),e.querySelectorAll?.(".wprm-recipe").forEach(a))})).observe(document.documentElement,{childList:!0,subtree:!0}),!o){let e=0;addEventListener("resize",(()=>{e&&cancelAnimationFrame(e),e=requestAnimationFrame((()=>s.forEach(c)))}),{passive:!0})}})()</script><script type="litespeed/javascript">window._wpemojiSettings={"baseUrl":"https:\/\/s.w.org\/images\/core\/emoji\/15.1.0\/72x72\/","ext":".png","svgUrl":"https:\/\/s.w.org\/images\/core\/emoji\/15.1.0\/svg\/","svgExt":".svg","source":{"concatemoji":"https:\/\/vegecravings.com\/wp-includes\/js\/wp-emoji-release.min.js?ver=6.8.1"}};
